// Jenkinsfile (예: 리포지토리 루트가 아닌 ci 폴더에 위치한 경우)
// 만약 이 Jenkinsfile을 사용하고 싶다면, Jenkins Job 설정에서 Script Path를 "ci/Jenkinsfile"로 지정하세요.
pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                // backend 폴더로 이동한 후, Gradle Wrapper를 이용하여 빌드 실행
                dir('backend') {
                    sh './gradlew build'
                }
            }
        }
//         stage('make zip'){
